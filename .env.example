# SQLite database file path (relative to project root).
# For production, use an absolute path or a managed database service.
DATABASE_URL=file:./nekrosol.db

# Secret used to sign Payload JWTs and cookies.
# Must be at least 32 characters. Generate with: openssl rand -hex 32
PAYLOAD_SECRET=your-secret-here-min-32-chars

# Comma-separated list of origins allowed by the CORS policy.
# Include all origins that the Expo mobile client or web client will connect from.
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Node environment. Set to "production" in deployed environments.
NODE_ENV=development
